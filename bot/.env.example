# Токен Telegram-бота — получите у @BotFather (обязательно)
TELEGRAM_BOT_TOKEN=

# Ключ TMDB API v3 — необязательно (большой каталог, новинки, аниме).
# Получить: https://www.themoviedb.org/settings/api
TMDB_API_KEY=
TMDB_LANGUAGE=ru-RU

# --- Только для веб-API (phase 2: вход через Telegram на сайте) ---
# Разрешённый источник для CORS — домен вашего сайта.
# Для GitHub Pages вида username.github.io укажите https://username.github.io
CORS_ORIGIN=*

# Секрет для подписи сессий сайта. Если пусто — выводится из токена бота.
SESSION_SECRET=

# Путь к локальной базе (docker-compose проставляет автоматически)
# CINEMA_DB=/data/userdata.db

# --- Turso (общая облачная база для Vercel-API и бота) ---
# Если заданы — и бот, и API используют одну базу Turso (libSQL).
# Создать: https://turso.tech  →  turso db create kinoflex  →  показать URL и токен.
# TURSO_DATABASE_URL=libsql://kinoflex-yourname.turso.io
# TURSO_AUTH_TOKEN=
