# Токен Telegram-бота — получите у @BotFather в Telegram (обязательно)
TELEGRAM_BOT_TOKEN=

# Ключ TMDB API v3 — необязательно.
# Без ключа бот рекомендует фильмы из локального каталога public-domain.
# С ключом — из огромной базы TMDB. Получить: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Язык метаданных TMDB
TMDB_LANGUAGE=ru-RU
